# Copier ce fichier vers .env puis renseigner les valeurs.
# Récupérables dans le dashboard Supabase : Project Settings > API.

# Référence du projet Supabase (ex: abcdefghijklmnopqrst)
VITE_SUPABASE_PROJECT_ID=""

# URL du projet Supabase (ex: https://<project-id>.supabase.co)
VITE_SUPABASE_URL=""

# Clé « anon / publishable ». Publique par design (protégée par les RLS).
VITE_SUPABASE_PUBLISHABLE_KEY=""

# Mêmes valeurs, sans le préfixe VITE_ : consommées côté edge functions Deno
# (voir supabase/functions/), pas exposées au bundle client.
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
